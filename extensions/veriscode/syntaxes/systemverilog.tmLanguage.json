{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SystemVerilog",
  "scopeName": "source.systemverilog",
  "fileTypes": ["sv", "svh", "v", "vh"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#storage-types" },
    { "include": "#module-decl" },
    { "include": "#keywords" },
    { "include": "#system-tasks" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.systemverilog",
          "match": "//.*$"
        },
        {
          "name": "comment.block.systemverilog",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.systemverilog",
          "match": "^\\s*`\\s*(define|include|ifdef|ifndef|else|elsif|endif|undef|timescale|default_nettype|resetall|celldefine|endcelldefine|unconnected_drive|nounconnected_drive|pragma|line)\\b.*$"
        },
        {
          "name": "variable.other.macro.systemverilog",
          "match": "`\\w+"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.systemverilog",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.systemverilog",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "sized based literal, e.g. 8'hFF, 4'b1010, 16'd255",
          "name": "constant.numeric.based.systemverilog",
          "match": "\\b[0-9]*\\s*'[sS]?[bBoOdDhH][0-9a-fA-FxXzZ_?]+"
        },
        {
          "comment": "unbased literal, e.g. 'x, 'z, '0, '1",
          "name": "constant.numeric.unbased.systemverilog",
          "match": "'[01xXzZ]\\b"
        },
        {
          "name": "constant.numeric.real.systemverilog",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.systemverilog",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.systemverilog",
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "patterns": [{ "include": "#strings" }]
    },
    "storage-types": {
      "patterns": [
        {
          "name": "storage.type.systemverilog",
          "match": "\\b(logic|reg|wire|wand|wor|tri|tri0|tri1|triand|trior|trireg|supply0|supply1|bit|byte|shortint|int|longint|integer|time|shortreal|real|realtime|void|chandle|string|event|uwire|genvar)\\b"
        },
        {
          "name": "storage.modifier.systemverilog",
          "match": "\\b(signed|unsigned|const|static|automatic|rand|randc|local|protected|virtual|pure|extern)\\b"
        }
      ]
    },
    "module-decl": {
      "patterns": [
        {
          "match": "\\b(module|macromodule|endmodule|interface|endinterface|program|endprogram|package|endpackage|class|endclass|primitive|endprimitive|config|endconfig)\\b",
          "name": "keyword.control.module.systemverilog"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.systemverilog",
          "match": "\\b(always|always_comb|always_ff|always_latch|initial|final|begin|end|if|else|case|casex|casez|endcase|default|for|foreach|while|do|repeat|forever|break|continue|return|fork|join|join_any|join_none|disable|wait|wait_order|assert|assume|cover|expect|restrict|unique|unique0|priority|generate|endgenerate|genvar)\\b"
        },
        {
          "name": "keyword.other.systemverilog",
          "match": "\\b(input|output|inout|ref|parameter|localparam|specparam|typedef|struct|union|enum|packed|function|endfunction|task|endtask|import|export|assign|deassign|force|release|posedge|negedge|edge|clocking|endclocking|covergroup|endgroup|coverpoint|bins|binsof|constraint|solve|before|extends|implements|interface|modport|sequence|endsequence|property|endproperty|program|new|this|super|null|inside|dist|with|matches|tagged|alias|timeunit|timeprecision|specify|endspecify|table|endtable|defparam|deassign|liblist|library|use)\\b"
        },
        {
          "name": "constant.language.systemverilog",
          "match": "\\b(1'b0|1'b1)\\b"
        }
      ]
    },
    "system-tasks": {
      "name": "support.function.systemverilog",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.systemverilog",
          "match": "(<=|>=|==|!=|===|!==|==\\?|!=\\?|&&|\\|\\||->|<->|\\+\\+|--|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|<<<=|>>>=|<<<|>>>|<<|>>|\\*\\*|~&|~\\||\\^~|~\\^)"
        },
        {
          "name": "keyword.operator.systemverilog",
          "match": "[+\\-*/%&|^~!<>=?:@#]"
        }
      ]
    }
  }
}
